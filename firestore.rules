rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'jhaysonjhay15@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner'])
      );
    }
    
    function isSuperOwner() {
      return isAuthenticated() && (
        request.auth.token.email == 'jhaysonjhay15@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')
      );
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalPrice', 'shippingAddress', 'status', 'createdAt']) &&
             data.userId is string &&
             data.items is list &&
             data.totalPrice is number &&
             data.status is string &&
             data.createdAt is string;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['message', 'isActive', 'createdAt']) &&
             data.message is string && data.message.size() <= 500 &&
             data.isActive is bool &&
             data.createdAt is string &&
             (!('productIds' in data) || data.productIds is list) &&
             (!('discountPercentage' in data) || (data.discountPercentage is int || data.discountPercentage is float)) &&
             (!('expiresAt' in data) || data.expiresAt is string);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'stock']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string &&
             data.price is number &&
             data.stock is number &&
             (!('socket' in data) || data.socket is string) &&
             (!('ramType' in data) || data.ramType is string) &&
             (!('wattage' in data) || data.wattage is number) &&
             (!('capacity' in data) || data.capacity is string) &&
             (!('isHighlyRecommended' in data) || data.isHighlyRecommended is bool);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string && data.productId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             (data.rating is int || data.rating is float) && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow get, list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId && (
        !('role' in request.resource.data) || request.resource.data.role == 'customer'
      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isSuperOwner()
      );
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }
    
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isSuperOwner();
    }

    match /pc_builds/{buildId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == (resource == null ? request.resource.data.userId : resource.data.userId) || isAdmin());
    }

    match /sales/{saleId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSale(request.resource.data);
    }

    match /prebuilts/{prebuiltId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ai_messages/{messageId} {
      allow read, write: if isAuthenticated() && request.auth.uid == (resource == null ? request.resource.data.userId : resource.data.userId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        isValidReview(request.resource.data) && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && (request.method == 'delete' || (isValidReview(request.resource.data) && request.resource.data.userId == resource.data.userId))) || 
        isAdmin()
      );
    }
  }
}
